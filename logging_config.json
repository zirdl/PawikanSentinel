{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "default": {
            "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        },
        "access": {
            "format": "%(asctime)s - %(levelname)s - %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        },
        "detailed": {
            "format": "%(asctime)s - %(name)s - %(levelname)s - [%(filename)s:%(lineno)d] - %(message)s",
            "datefmt": "%Y-%m-%d %H:%M:%S"
        }
    },
    "handlers": {
        "console": {
            "formatter": "default",
            "class": "logging.StreamHandler",
            "stream": "ext://sys.stderr"
        },
        "inference_file": {
            "formatter": "detailed",
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "logs/inference.log",
            "maxBytes": 10485760,
            "backupCount": 5
        },
        "access_file": {
            "formatter": "access",
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "logs/access.log",
            "maxBytes": 5242880,
            "backupCount": 3
        },
        "system_file": {
            "formatter": "default",
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "logs/system.log",
            "maxBytes": 2097152,
            "backupCount": 3
        }
    },
    "loggers": {
        "uvicorn": {
            "handlers": ["console", "access_file"],
            "level": "WARNING"
        },
        "uvicorn.error": {
            "level": "WARNING"
        },
        "uvicorn.access": {
            "handlers": ["access_file"],
            "level": "INFO",
            "propagate": false
        },
        "src.inference": {
            "handlers": ["console", "inference_file"],
            "level": "INFO"
        },
        "src.api.system": {
            "handlers": ["console", "system_file"],
            "level": "INFO"
        }
    }
}