# iprog SMS Configuration (replaces Semaphore)
IPROG_API_TOKEN=your_iprog_api_token_here
IPROG_SENDER_NAME=PawikanSentinel

# For backward compatibility - will be ignored when using iprog
# SEMAPHORE_API_KEY=ignored_when_using_iprog
# SEMAPHORE_SENDER_NAME=ignored_when_using_iprog
# TWILIO_ACCOUNT_SID=ignored_when_using_iprog
# TWILIO_AUTH_TOKEN=ignored_when_using_iprog
# TWILIO_PHONE_NUMBER=ignored_when_using_iprog

# SMS Notification Cooldown (in minutes)
SMS_NOTIFICATION_COOLDOWN=10

# YOLO11 Model Configuration (local inference - no Docker needed)
# Model is auto-downloaded from HuggingFace (BVRA/TurtleDetector) on first run
YOLO_MODEL_DIR=models
YOLO_INPUT_SIZE=320
YOLO_CONF_THRESHOLD=0.25

# Detection Configuration
CONFIDENCE_THRESHOLD=0.8
FRAME_SKIP=10
RESIZE_WIDTH=320
RESIZE_HEIGHT=320
CPU_THRESHOLD=80
TEMP_THRESHOLD=80
MAX_INFERENCE_WORKERS=2

# Backups
PAWIKAN_BACKUP_DIR=backups
PAWIKAN_BACKUP_RETENTION=7

# Directories
DETECTIONS_DIR=detections
